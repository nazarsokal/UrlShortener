## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Latest template:
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# =========================
# User-specific files
# =========================
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.env

# macOS
.DS_Store

# Mono auto generated files
mono_crash.*

# =========================
# Build folders
# =========================
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Aa]rtifacts/
.artifacts/

[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/

x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/

# =========================
# Visual Studio
# =========================
.vs/
.vshistory/
Generated\ Files/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

.history/

# =========================
# Test results
# =========================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# =========================
# NuGet
# =========================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

*.nuget.props
*.nuget.targets

# =========================
# ASP.NET / Publish
# =========================
publish/
PublishScripts/

*.azurePubxml
*.pubxml
*.publishproj
*.publishsettings

# Uncomment if generated
# wwwroot/

# =========================
# Node.js
# =========================
node_modules/

# =========================
# Logs / Temp
# =========================
*.log
*.tmp
*.cache
*.pidb
*.svclog

# =========================
# Database files
# =========================
*.mdf
*.ldf
*.ndf

# =========================
# Rider / ReSharper
# =========================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# =========================
# Coverage tools
# =========================
*.dotCover
.axoCover/*
!.axoCover/settings.json

coverage*.json
coverage*.xml
coverage*.info

# =========================
# Azure / AWS
# =========================
.aws-sam

# =========================
# Python
# =========================
__pycache__/
*.pyc

# =========================
# Misc
# =========================
*.dbmdl
*.jfm
*.pfx
*.opendb
*.VC.db
*.VC.VC.opendb

# Local history
**/.localhistory/

# Package managers
paket-files/

# FAKE
**/.fake/

# Ionide
**/.ionide/

# MFractors
**/.mfractor/